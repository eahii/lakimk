---
import PageLayout from '../layouts/PageLayout.astro'
---
<PageLayout
  title="Asianajajat"
  description="Asianajajat Satu Miinala ja Niina Kaisanlahti. Koulutus, kokemus, erikoisalat ja yhteystiedot. Rovaniemi ja Kemijärvi."
  caption="Tieto — toimiston väki"
  heading="Kaksi asian­ajajaa.<br/>Koko toimisto."
  intro="Kun asioit meillä, saat käsiisi yhden näistä kahdesta — ei assistentin, ei junioria. Alla heidän taustansa, kokemuksensa ja tavoittamisensa."
  breadcrumb="Asianajajat"
>

<!-- BIOS -->
<section class="bios">
  <div class="container-editorial-wide">

    <!-- SATU -->
    <article class="bio" id="satu">
      <div class="bio-portrait">
        <div class="bio-portrait-img">
          <img src="/images/satu.webp" alt="Asianajaja Satu Miinala" />
        </div>
        <div class="bio-portrait-meta">
          Asianajaja · VT<br/>
          Asianajajaliiton jäsen<br/>
          Toimipaikka — Rovaniemi
        </div>
      </div>
      <div>
        <h2 class="bio-name">Satu Miinala</h2>
        <span class="bio-role">Asianajaja, varatuomari · Osakas</span>
        <p class="bio-lead">
          Yli kahden vuosikymmenen kokemus asianajosta Lapissa. Erityis­alana
          perhe- ja perintöoikeudelliset asiat — kaikki ne tilanteet, joissa
          oikeuden kysymykset kietoutuvat ihmisten elämään.
        </p>
        <div class="bio-body">
          <p>
            Satu on hoitanut vuosien varrella satoja avioeroja ja ositusta,
            perunkirjoituksia, perinnönjakoja ja lapsen huoltoa koskevia
            asioita. Hän on toiminut pesänselvittäjänä ja pesänjakajana
            käräjäoikeuden määräämänä useita kertoja.
          </p>
          <p>
            Työssään Satu on rauhallinen mutta suorasanainen. Hän kertoo, miten
            asia oikeudellisesti on — ja sanoo myös, kun sovinto on parempi
            kuin oikeudenkäynti. Asiakkaat kuvaavat häntä "juristiksi, joka
            kuuntelee".
          </p>
        </div>

        <div class="bio-facts">
          <div>
            <span class="bio-fact-label">Koulutus</span>
            <div class="bio-fact-value">
              <ul>
                <li>Oikeustieteen maisteri (OTM), Lapin yliopisto</li>
                <li>Varatuomari (VT), auskultointi Rovaniemen HO</li>
                <li>Asianajajatutkinto</li>
              </ul>
            </div>
          </div>
          <div>
            <span class="bio-fact-label">Erikois­alat</span>
            <div class="bio-fact-value">
              <ul>
                <li>Avioero &amp; ositus</li>
                <li>Perunkirjoitus &amp; perinnönjako</li>
                <li>Testamentit &amp; lahjakirjat</li>
                <li>Lapsen huolto &amp; tapaamisoikeus</li>
              </ul>
            </div>
          </div>
          <div>
            <span class="bio-fact-label">Jäsenyydet</span>
            <div class="bio-fact-value">
              <ul>
                <li>Suomen Asianajaja­liitto</li>
                <li>Lapin paikallisosasto</li>
              </ul>
            </div>
          </div>
          <div>
            <span class="bio-fact-label">Kielet</span>
            <div class="bio-fact-value">
              <ul>
                <li>Suomi — äidinkieli</li>
                <li>Englanti — sujuva</li>
                <li>Ruotsi — neuvottelutaito</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="bio-contact">
          <div class="bio-contact-item">
            <span class="lbl">Puhelin</span>
            <a href="tel:+358404876650">040 487 665</a>
          </div>
          <div class="bio-contact-item">
            <span class="lbl">Sähköposti</span>
            <a href="mailto:satu@miinalakaisanlahti.fi">satu@miinalakaisanlahti.fi</a>
          </div>
        </div>
      </div>
    </article>

    <!-- NIINA -->
    <article class="bio reversed" id="niina">
      <div class="bio-portrait">
        <div class="bio-portrait-img">
          <img src="/images/niina.webp" alt="Asianajaja Niina Kaisanlahti" />
        </div>
        <div class="bio-portrait-meta">
          Asianajaja · VT<br/>
          Asianajajaliiton jäsen<br/>
          Toimipaikat — Kemijärvi &amp; Rovaniemi
        </div>
      </div>
      <div>
        <h2 class="bio-name">Niina Kaisanlahti</h2>
        <span class="bio-role">Asianajaja, varatuomari · Osakas</span>
        <p class="bio-lead">
          Rikosasioiden, riita-asioiden ja asianomistajan avustamisen
          erikoistuja. Toimii molemmilla toimipaikoilla — Kemijärven
          toimisto on hänen kotitukikohtansa.
        </p>
        <div class="bio-body">
          <p>
            Niina on toiminut avustajana satoja kertoja käräjä- ja
            hovioikeudessa. Hän on puolustanut syytettyjä ja avustanut
            asianomistajia erityisesti pahoinpitely-, seksuaalirikos- ja
            talousrikosasioissa. Kiireellisissä rikosasioissa hän ottaa
            yhteydenotot vastaan saman päivän aikana.
          </p>
          <p>
            Riita-asioissa Niina lähtee aina siitä, mitä asiakas todella
            tavoittelee — ja päämäärä saavutetaan usein sovintoneuvottelun
            kautta, ei käräjöimällä. Kun oikeudenkäynti on välttämätön, hän
            tuntee salin.
          </p>
        </div>

        <div class="bio-facts">
          <div>
            <span class="bio-fact-label">Koulutus</span>
            <div class="bio-fact-value">
              <ul>
                <li>Oikeustieteen maisteri (OTM), Lapin yliopisto</li>
                <li>Varatuomari (VT), auskultointi Lapin KO</li>
                <li>Asianajajatutkinto</li>
              </ul>
            </div>
          </div>
          <div>
            <span class="bio-fact-label">Erikois­alat</span>
            <div class="bio-fact-value">
              <ul>
                <li>Rikosasiat — puolustus &amp; asianomistaja</li>
                <li>Riita-asiat &amp; sovintoneuvottelut</li>
                <li>Työoikeus</li>
                <li>Vahingon­korvausasiat</li>
              </ul>
            </div>
          </div>
          <div>
            <span class="bio-fact-label">Jäsenyydet</span>
            <div class="bio-fact-value">
              <ul>
                <li>Suomen Asianajaja­liitto</li>
                <li>Lapin paikallisosasto</li>
              </ul>
            </div>
          </div>
          <div>
            <span class="bio-fact-label">Kielet</span>
            <div class="bio-fact-value">
              <ul>
                <li>Suomi — äidinkieli</li>
                <li>Englanti — sujuva</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="bio-contact">
          <div class="bio-contact-item">
            <span class="lbl">Puhelin</span>
            <a href="tel:+358400914316">0400 914 316</a>
          </div>
          <div class="bio-contact-item">
            <span class="lbl">Sähköposti</span>
            <a href="mailto:niina@miinalakaisanlahti.fi">niina@miinalakaisanlahti.fi</a>
          </div>
        </div>
      </div>
    </article>

  </div>
</section>

<!-- TRUST -->
<section class="trust">
  <div class="container-editorial-wide">
    <div class="trust-grid">
      <div class="trust-mark">
        <img src="/images/asianajaja-merkki.webp" alt="Suomen Asianajajaliiton merkki" />
      </div>
      <div class="trust-copy">
        <span class="caption-editorial">Suomen asianajaja­liitto</span>
        <h2 class="trust-heading">Asianajaja­nimikettä saa käyttää vain liittoon kuuluva juristi.</h2>
        <p>
          Asianajajalla on laissa säädetty vaitiolovelvollisuus, pakollinen
          vastuuvakuutus ja liiton valvoma kurinpito. Se tarkoittaa sinulle
          kolmea asiaa: kaikki kertomasi pysyy luottamuksellisena, virheen
          sattuessa vahinko korvataan, ja epäselvissä tilanteissa sinulla on
          riippumaton valvontalautakunta tukenasi.
        </p>
      </div>
    </div>
  </div>
</section>

<!-- CONTACT BAND -->
<section class="contact-band">
  <div class="container-editorial-wide">
    <div>
      <h2>Ota yhteyttä suoraan asianajajaan.</h2>
      <p>
        Ei vaihdetta, ei assistenttia. Soita tai laita sähköpostia siihen
        asianajajaan, jonka erityisala vastaa asiaasi — tai varaa aika
        verkossa, niin otamme itse yhteyttä.
      </p>
    </div>
    <div class="contact-band-actions">
      <a href="tel:+358404876650">
        <span><span class="lbl">Satu · Perhe- &amp; perintöasiat</span><span class="val">040 487 665</span></span>
        <span>→</span>
      </a>
      <a href="tel:+358400914316">
        <span><span class="lbl">Niina · Rikos- &amp; riita-asiat</span><span class="val">0400 914 316</span></span>
        <span>→</span>
      </a>
      <a href="/yhteystiedot">
        <span><span class="lbl">Yhteydenottolomake</span><span class="val">Varaa aika verkossa</span></span>
        <span>→</span>
      </a>
    </div>
  </div>
</section>

</PageLayout>

<style>
  /* Large attorney card — full bio */
  .bios {
    padding: 5rem 0;
    background: hsl(var(--background));
  }
  @media (min-width: 768px) { .bios { padding: 7rem 0; } }
  .bio {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    padding-bottom: 6rem;
    margin-bottom: 6rem;
    border-bottom: 1px solid hsl(var(--border));
  }
  .bio:last-child { border-bottom: 0; margin-bottom: 0; padding-bottom: 0; }
  @media (min-width: 900px) {
    .bio { grid-template-columns: 22rem 1fr; gap: 5rem; }
    .bio.reversed { grid-template-columns: 1fr 22rem; }
    .bio.reversed .bio-portrait { order: 2; }
  }
  .bio-portrait { position: relative; }
  .bio-portrait-img {
    height: 480px;
    background: hsl(var(--secondary));
    overflow: hidden;
    margin-bottom: 1.5rem;
  }
  .bio-portrait-img img {
    width: 100%; height: 100%;
    object-fit: cover;
    filter: brightness(1.02) saturate(0.92) sepia(0.08);
  }
  .bio-portrait-meta {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.6875rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    line-height: 1.8;
  }
  .bio-name {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(2.25rem, 1.4rem + 2.5vw, 3.25rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.015em;
    margin-bottom: 0.5rem;
  }
  .bio-role {
    font-family: 'Inter', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: hsl(var(--primary));
    font-weight: 500;
    margin-bottom: 2rem;
    display: block;
  }
  .bio-lead {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-style: italic;
    font-size: clamp(1.25rem, 1rem + 0.8vw, 1.625rem);
    line-height: 1.4;
    color: hsl(var(--foreground));
    margin-bottom: 2rem;
    max-width: 34rem;
    font-weight: 400;
  }
  .bio-body {
    font-size: 1.0625rem;
    line-height: 1.75;
    color: hsl(var(--foreground) / 0.85);
    font-weight: 300;
    max-width: 34rem;
  }
  .bio-body p { margin-bottom: 1.25rem; }
  .bio-facts {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 3rem;
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid hsl(var(--border));
    max-width: 38rem;
  }
  @media (min-width: 600px) { .bio-facts { grid-template-columns: 1fr 1fr; } }
  .bio-fact-label {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    font-weight: 500;
    margin-bottom: 0.5rem;
    display: block;
  }
  .bio-fact-value {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.0625rem;
    line-height: 1.5;
    color: hsl(var(--foreground));
    font-weight: 400;
  }
  .bio-fact-value ul {
    list-style: none; padding: 0; margin: 0;
    font-family: 'Inter', sans-serif;
    font-size: 0.9375rem;
    font-weight: 400;
    line-height: 1.7;
  }
  .bio-contact {
    margin-top: 2.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid hsl(var(--border));
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 38rem;
  }
  @media (min-width: 600px) { .bio-contact { grid-template-columns: 1fr 1fr; } }
  .bio-contact-item { font-size: 0.9375rem; line-height: 1.6; }
  .bio-contact-item .lbl {
    font-family: 'Inter', sans-serif;
    font-size: 0.6875rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: hsl(var(--muted-foreground));
    font-weight: 500;
    margin-bottom: 0.5rem;
    display: block;
  }
  .bio-contact-item a {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.25rem;
    line-height: 1.3;
    color: hsl(var(--foreground));
    border-bottom: 1px solid hsl(var(--border));
    padding-bottom: 2px;
    transition: color 300ms, border-color 300ms;
    display: inline-block;
  }
  .bio-contact-item a:hover {
    color: hsl(var(--primary));
    border-bottom-color: hsl(var(--primary));
  }
  /* Trust strip */
  .trust {
    padding: 5rem 0;
    background: hsl(var(--secondary) / 0.4);
    border-top: 1px solid hsl(var(--border));
    border-bottom: 1px solid hsl(var(--border));
  }
  @media (min-width: 768px) { .trust { padding: 7rem 0; } }
  .trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
  }
  @media (min-width: 900px) { .trust-grid { grid-template-columns: 10rem 1fr; gap: 5rem; } }
  .trust-mark {
    width: 9rem; height: 9rem;
    background: hsl(var(--background));
    border-radius: 9999px;
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    padding: 1rem;
  }
  .trust-mark img { width: 100%; height: auto; object-fit: contain; }
  .trust-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: clamp(1.75rem, 1.3rem + 1.5vw, 2.5rem);
    font-weight: 500;
    font-style: italic;
    margin-bottom: 1rem;
    margin-top: 1rem;
  }
  .trust-copy p {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: hsl(var(--foreground) / 0.8);
    font-weight: 300;
    max-width: 42rem;
  }
</style>
